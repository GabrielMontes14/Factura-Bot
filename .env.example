# ─── SUPABASE ────────────────────────────────────────────────
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_KEY=tu_anon_key_aqui
# ─── TELEGRAM ────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=tu_telegram_bot_token_aqui
TELEGRAM_ADMIN_CHAT_ID=tu_chat_id_aqui

# ─── GROQ ────────────────────────────────────────────────────
GROQ_API_KEY=gsk_tu_clave_aqui
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_MODEL_FALLBACK=llama-3.2-11b-vision-preview
GROQ_MODEL2=llama-3.3-70b-speculative

# ─── CONFIGURACIÓN DEL BOT ───────────────────────────────────
# Puedes poner varios grupos separados por comas
GRUPOS_PERMITIDOS=Grupo 1,Grupo 2
TABLA_PRODUCTOS=productos

# ─── APROBACIÓN ──────────────────────────────────────────────
# Tiempo en ms antes de que expire una factura sin aprobar (default: 10 min)
APROBACION_TIMEOUT_MS=600000

# ─── REINTENTOS ──────────────────────────────────────────────
MAX_RETRIES=3
RETRY_DELAY_MS=1000

# ─── RECONEXIÓN ──────────────────────────────────────────────
RECONEXION_DELAY_MS=5000
MAX_RECONEXIONES=10

# ─── DEBUG (true para ver logs detallados) ───────────────────
DEBUG=false
